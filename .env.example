# Copy to .env.local for local development (never commit .env.local).
# On Vercel: set these in Project Settings → Environment Variables.

# OpenRouter API key (https://openrouter.ai/keys) — used for rebuttal feedback
OPENROUTER_API_KEY=

# Optional override (default in code: NVIDIA Nemotron 3 Super). Example free tier:
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=
